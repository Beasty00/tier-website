# App
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/your-server
NEXT_PUBLIC_SERVER_IP=

# PostgreSQL / Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tier_testing?schema=public

# Auth
JWT_SECRET=change-me-before-production
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4000/auth/discord/callback

# Queue
QUEUE_LIMIT=32
GLOBAL_COOLDOWN_HOURS=24
GAMEMODE_COOLDOWN_HOURS=72
DISABLE_DATABASE=true
