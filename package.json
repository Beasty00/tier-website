                         "dotenv":  "^16.4.7",
                         "express":  "^4.21.2",
                         "express-rate-limit":  "^7.5.0",
                         "framer-motion":  "^11.18.2",
                         "helmet":  "^8.0.0",
                         "jsonwebtoken":  "^9.0.2",
                         "lucide-react":  "^0.468.0",
                         "morgan":  "^1.10.0",
                         "next":  "^15.0.0",
                         "react":  "^19.0.0",
                         "react-dom":  "^19.0.0",
                         "serverless-http":  "^3.2.0",
                         "zod":  "^3.24.1"
                     },
    "devDependencies":  {
                            "@types/bcryptjs":  "^2.4.6",
